// This is a TypeScript configuration file for a React project.
{
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "outDir": "dist",
    "rootDir": "app", // Update this to match your source directory
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "moduleResolution": "node",
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["app/**/*", ".next/types/**/*.ts"], // Update this to include your source files
  "exclude": ["node_modules", "dist"]
}