// This is a TypeScript configuration file for a React project.
{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "outDir": "dist",
    "rootDir": "app", // Update this to match your source directory
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["app/**/*"], // Update this to include your source files
  "exclude": ["node_modules", "dist"]
}